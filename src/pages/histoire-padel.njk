<!-- Timeline -->
<section class="timeline">
    <div class="timeline__line" id="timelineLine"></div>

    <!-- 1969 -->
    <div class="timeline__item" data-year="1969">
        <div class="timeline__dot"></div>
        <div class="timeline__card">
            <div class="timeline__year">1969</div>
            <div class="timeline__flag">🇲🇽</div>
            <h2 class="timeline__title">L'invention du padel</h2>
            <p class="timeline__location">Acapulco, Mexique</p>
            <p class="timeline__text">L'homme d'affaires <strong>Enrique Corcuera</strong> fait construire un terrain de 20×10&nbsp;m entouré de murs dans sa propriété "Las Brisas". Faute de place pour un court de tennis, il adapte les règles avec des raquettes en bois — et les murs deviennent la signature du sport.</p>
            <div class="timeline__stat">
                <span class="timeline__stat-number">1</span>
                <span class="timeline__stat-label">terrain au monde</span>
            </div>
        </div>
    </div>

    <!-- 1974 -->
    <div class="timeline__item timeline__item--right" data-year="1974">
        <div class="timeline__dot"></div>
        <div class="timeline__card">
            <div class="timeline__year">1974</div>
            <div class="timeline__flag">🇪🇸</div>
            <h2 class="timeline__title">Le padel arrive en Europe</h2>
            <p class="timeline__location">Marbella, Espagne</p>
            <p class="timeline__text">Le Prince <strong>Alfonso de Hohenlohe</strong>, ami de Corcuera, fait construire les deux premiers courts d'Espagne au Marbella Club Hotel après avoir découvert le sport à Acapulco. C'est le début de l'expansion européenne.</p>
            <div class="timeline__stat">
                <span class="timeline__stat-number">2</span>
                <span class="timeline__stat-label">premiers courts en Espagne</span>
            </div>
        </div>
    </div>

    <!-- 1975 -->
    <div class="timeline__item" data-year="1975">
        <div class="timeline__dot"></div>
        <div class="timeline__card">
            <div class="timeline__year">1975</div>
            <div class="timeline__flag">🇦🇷</div>
            <h2 class="timeline__title">L'Argentine adopte le padel</h2>
            <p class="timeline__location">Buenos Aires, Argentine</p>
            <p class="timeline__text">L'Argentin <strong>Julio Menditeguy</strong>, habitué du Marbella Club, importe le padel dans son pays. Les premiers terrains sont construits au Club Tortugas, posant les bases d'un phénomène qui deviendra le sport national n°2.</p>
            <div class="timeline__stat">
                <span class="timeline__stat-number">→</span>
                <span class="timeline__stat-label">futur sport n°2 du pays</span>
            </div>
        </div>
    </div>

    <!-- 1982 -->
    <div class="timeline__item timeline__item--right" data-year="1982">
        <div class="timeline__dot"></div>
        <div class="timeline__card">
            <div class="timeline__year">1982</div>
            <div class="timeline__flag">🇦🇷</div>
            <h2 class="timeline__title">Explosion populaire en Argentine</h2>
            <p class="timeline__location">Argentine</p>
            <p class="timeline__text">Après une décennie dans les cercles privés, le padel sort des clubs huppés et se démocratise massivement. L'Argentine devient le premier grand marché mondial du padel, avec des milliers de terrains construits en quelques années.</p>
            <div class="timeline__stat">
                <span class="timeline__stat-number">x100</span>
                <span class="timeline__stat-label">terrains en une décennie</span>
            </div>
        </div>
    </div>

    <!-- 1991 -->
    <div class="timeline__item" data-year="1991">
        <div class="timeline__dot"></div>
        <div class="timeline__card">
            <div class="timeline__year">1991</div>
            <div class="timeline__flag">🌍</div>
            <h2 class="timeline__title">Création de la FIP</h2>
            <p class="timeline__location">Madrid, Espagne</p>
            <p class="timeline__text">La <strong>Fédération Internationale de Padel</strong> est fondée le 12 juillet à Madrid par les fédérations argentine, espagnole et uruguayenne. C'est la première structure officielle de gouvernance mondiale du sport.</p>
            <div class="timeline__stat">
                <span class="timeline__stat-number">3</span>
                <span class="timeline__stat-label">pays fondateurs</span>
            </div>
        </div>
    </div>

    <!-- 1992 -->
    <div class="timeline__item timeline__item--right" data-year="1992">
        <div class="timeline__dot"></div>
        <div class="timeline__card">
            <div class="timeline__year">1992</div>
            <div class="timeline__flag">🏆</div>
            <h2 class="timeline__title">Premier Championnat du Monde</h2>
            <p class="timeline__location">Madrid & Séville, Espagne</p>
            <p class="timeline__text">Le tout premier World Padel Championship est organisé en Espagne, avec les finales lors de l'Expo 92 à Séville. La même année, la France intègre officiellement la FIP et participe à l'épreuve inaugurale.</p>
            <div class="timeline__stat">
                <span class="timeline__stat-number">1992</span>
                <span class="timeline__stat-label">aussi l'année du padel en France</span>
            </div>
        </div>
    </div>

    <!-- 2013 -->
    <div class="timeline__item" data-year="2013">
        <div class="timeline__dot"></div>
        <div class="timeline__card">
            <div class="timeline__year">2013</div>
            <div class="timeline__flag">🎬</div>
            <h2 class="timeline__title">Naissance du World Padel Tour</h2>
            <p class="timeline__location">Espagne</p>
            <p class="timeline__text">Le <strong>World Padel Tour</strong> succède au Padel Pro Tour et devient le circuit professionnel de référence. Il organise 20 à 30 tournois par an et professionnalise le sport à l'échelle mondiale.</p>
            <div class="timeline__stat">
                <span class="timeline__stat-number">30</span>
                <span class="timeline__stat-label">tournois par saison</span>
            </div>
        </div>
    </div>

    <!-- 2014 -->
    <div class="timeline__item timeline__item--right" data-year="2014">
        <div class="timeline__dot"></div>
        <div class="timeline__card">
            <div class="timeline__year">2014</div>
            <div class="timeline__flag">🇫🇷</div>
            <h2 class="timeline__title">La FFT prend les rênes en France</h2>
            <p class="timeline__location">France</p>
            <p class="timeline__text">La <strong>Fédération Française de Tennis</strong> reprend officiellement la gestion du padel en France, donnant au sport un cadre fédéral solide. L'accélération est immédiate : les clubs et terrains se multiplient sur tout le territoire.</p>
            <div class="timeline__stat">
                <span class="timeline__stat-number">FFT</span>
                <span class="timeline__stat-label">accélérateur du padel français</span>
            </div>
        </div>
    </div>

    <!-- 2022-2024 -->
    <div class="timeline__item" data-year="2024">
        <div class="timeline__dot"></div>
        <div class="timeline__card">
            <div class="timeline__year">2022–24</div>
            <div class="timeline__flag">⚡</div>
            <h2 class="timeline__title">Unification du circuit mondial</h2>
            <p class="timeline__location">International</p>
            <p class="timeline__text">QSI (Qatar Sports Investments) lance <strong>Premier Padel</strong> en 2022 sous l'égide de la FIP, puis acquiert le World Padel Tour en 2023. En 2024, les deux circuits fusionnent sous une bannière unique, unifiant enfin le padel professionnel mondial.</p>
            <div class="timeline__stat">
                <span class="timeline__stat-number">1</span>
                <span class="timeline__stat-label">circuit unifié</span>
            </div>
        </div>
    </div>

    <!-- 2025+ -->
    <div class="timeline__item timeline__item--right" data-year="2025">
        <div class="timeline__dot"></div>
        <div class="timeline__card timeline__card--future">
            <div class="timeline__year">2025 →</div>
            <div class="timeline__flag">🏅</div>
            <h2 class="timeline__title">Cap sur les JO 2032</h2>
            <p class="timeline__location">International → Brisbane, Australie</p>
            <p class="timeline__text">Avec <strong>87 fédérations nationales</strong> et plus de 30 millions de pratiquants dans 140 pays, le padel frappe aux portes des Jeux Olympiques. Brisbane 2032 est l'objectif affiché de la FIP.</p>
            <div class="timeline__stats-row">
                <div class="timeline__stat">
                    <span class="timeline__stat-number">30M</span>
                    <span class="timeline__stat-label">joueurs</span>
                </div>
                <div class="timeline__stat">
                    <span class="timeline__stat-number">140</span>
                    <span class="timeline__stat-label">pays</span>
                </div>
                <div class="timeline__stat">
                    <span class="timeline__stat-number">2032</span>
                    <span class="timeline__stat-label">objectif JO</span>
                </div>
            </div>
        </div>
    </div>

</section>

