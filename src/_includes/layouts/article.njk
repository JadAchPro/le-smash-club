---
layout: layouts/base.njk
---

<!-- JSON-LD: Article -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ title }}",
    "description": "{{ seoDescription or excerpt or subtitle or '' }}",
    "datePublished": "{{ date | dateISO }}",
    "dateModified": "{{ lastmod | dateISO if lastmod else date | dateISO }}",
    {% if image %}"image": "{{ site.url }}{{ image }}",{% endif %}
    "author": {
        "@type": "Person",
        "name": "{{ site.author }}",
        "url": "{{ site.url }}/a-propos/"
    },
    "publisher": {
        "@type": "Organization",
        "name": "{{ site.name }}"
    },
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ site.url }}{{ page.url }}"
    }
    {% if category %},"articleSection": "{{ category }}"{% endif %}
}
</script>

<!-- JSON-LD: BreadcrumbList -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Accueil",
            "item": "{{ site.url }}/"
        }
        {% if sport %},
        {
            "@type": "ListItem",
            "position": 2,
            "name": "{{ sport }}",
            "item": "{{ site.url }}/{{ sport | slugify }}/"
        },
        {
            "@type": "ListItem",
            "position": 3,
            "name": "{{ title }}"
        }
        {% else %},
        {
            "@type": "ListItem",
            "position": 2,
            "name": "{{ title }}"
        }
        {% endif %}
    ]
}
</script>

{% if faq %}
<!-- JSON-LD: FAQPage -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {% for item in faq %}
        {
            "@type": "Question",
            "name": "{{ item.question }}",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "{{ item.answer }}"
            }
        }{% if not loop.last %},{% endif %}
        {% endfor %}
    ]
}
</script>
{% endif %}

<!-- Reading progress bar -->
<div class="reading-progress" id="readingProgress"></div>

<!-- Article layout: sidebar TOC + content -->
<div class="article-layout">
    <!-- Sidebar TOC (generated by JS) -->
    <aside class="article-sidebar" id="articleSidebar"></aside>

    <!-- Article main content -->
    <div class="article-main">
        <!-- Breadcrumb navigation -->
        <nav class="breadcrumb" aria-label="Fil d'Ariane">
            <a href="/">Accueil</a>
            {% if sport %}
            <span class="breadcrumb__separator">›</span>
            <a href="/{{ sport | slugify }}/">{{ sport }}</a>
            {% endif %}
            {% if category and category != sport %}
            <span class="breadcrumb__separator">›</span>
            <a href="/{{ sport | slugify }}/{{ category | slugify }}/">{{ category }}</a>
            {% endif %}
            <span class="breadcrumb__separator">›</span>
            <span class="breadcrumb__current">{{ title }}</span>
        </nav>

        <!-- Article Hero Image -->
        {% if image %}
        <div class="article-hero">
            <img src="{{ image }}" alt="{{ title }}" width="800" height="450" loading="lazy">
        </div>
        {% endif %}

        <!-- Article Header -->
        <header class="article-header">
            <div class="article-header__meta">
                {% if category %}
                    {% tag category %}
                {% endif %}
                {% if tags %}
                    {% for t in tags %}
                        {% if t != "articles" %}{% tag t %}{% endif %}
                    {% endfor %}
                {% endif %}
                <span class="article-header__date">
                    <time datetime="{{ date | dateISO }}">{{ date | dateFr }}</time>
                    · {{ content | readingTime }}  de lecture
                </span>
            </div>
            <h1 class="article-header__title">{{ title }}</h1>
            {% if subtitle %}
            <p class="article-header__subtitle">{{ subtitle }}</p>
            {% endif %}
        </header>

        <!-- Article Body -->
        <div class="article-body">
            {{ content | safe }}
        </div>

        {% if faq %}
        <!-- FAQ Section (visible HTML — matches JSON-LD FAQPage) -->
        <section class="article-faq">
            <h2>Questions fréquentes</h2>
            {% for item in faq %}
            <details class="faq-item"{% if loop.first %} open{% endif %}>
                <summary class="faq-item__question">{{ item.question }}</summary>
                <div class="faq-item__answer">
                    <p>{{ item.answer }}</p>
                </div>
            </details>
            {% endfor %}
        </section>
        {% endif %}

        <!-- Share buttons -->
        <div class="share-bar">
        <span class="share-bar__label">Partager</span>
        <a href="https://twitter.com/intent/tweet?text={{ title | urlencode }}&url={{ site.url }}{{ page.url | urlencode }}" target="_blank" rel="noopener" class="share-btn share-btn--twitter" aria-label="Partager sur Twitter">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ site.url }}{{ page.url | urlencode }}" target="_blank" rel="noopener" class="share-btn share-btn--facebook" aria-label="Partager sur Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://wa.me/?text={{ title | urlencode }}%20{{ site.url }}{{ page.url | urlencode }}" target="_blank" rel="noopener" class="share-btn share-btn--whatsapp" aria-label="Partager sur WhatsApp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
        <button class="share-btn share-btn--copy" aria-label="Copier le lien" onclick="navigator.clipboard.writeText('{{ site.url }}{{ page.url }}');this.innerHTML='<svg width=&quot;18&quot; height=&quot;18&quot; viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot;><path d=&quot;M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z&quot;/></svg>';setTimeout(()=>this.innerHTML='<svg width=&quot;18&quot; height=&quot;18&quot; viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot;><path d=&quot;M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z&quot;/></svg>',2000)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/></svg>
        </button>
    </div>

    <!-- Smart Recommendations: same category first, then fill with others -->
    {% set sameCatArticles = collections.articles | sameCategoryExclude(category, page.url) | limit(2) %}
    {% if sameCatArticles.length >= 2 %}
        {% set recommendedArticles = sameCatArticles %}
    {% else %}
        {% set recommendedArticles = collections.articles | exclude(page.url) | limit(2) %}
    {% endif %}

    {% if recommendedArticles.length > 0 %}
    <section class="article-recommendations">
        <div class="section__header">
            <h2 class="section__title">À lire aussi{% if category %} dans {{ category }}{% endif %}</h2>
        </div>
        <div class="cards-grid cards-grid--2col">
            {% for article in recommendedArticles %}
                {% include "partials/card-article.njk" %}
            {% endfor %}
        </div>
    </section>
    {% endif %}
    </div>{# /article-main #}

    <!-- Right sidebar: infographies + newsletter -->
    <aside class="article-sidebar-right">
        {% include "partials/sidebar-right.njk" %}
    </aside>
</div>{# /article-layout #}

<!-- Newsletter CTA -->
<div class="container" style="padding-top: 48px; padding-bottom: 48px;">
    {% include "partials/newsletter.njk" %}
</div>
