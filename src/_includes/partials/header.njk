<header class="header">
    <div class="header__inner">
        <a href="/" class="header__logo">
            <span class="header__logo-text">Le Smash Club<span class="header__tagline">Le magazine padel & pickleball</span></span>
        </a>
        <nav class="header__nav" id="mainNav">
            <a href="/" {% if page.url === "/" %}aria-current="page"{% endif %}>Accueil</a>
            <a href="/padel/" {% if page.url.startsWith("/padel/") %}aria-current="page"{% endif %}>Padel</a>
            <a href="/pickleball/" {% if page.url.startsWith("/pickleball/") %}aria-current="page"{% endif %}>Pickleball</a>
            <a href="/actualites/" {% if page.url.startsWith("/actualites/") %}aria-current="page"{% endif %}>Actualités</a>
            <a href="/ressources/" {% if page.url.startsWith("/ressources/") %}aria-current="page"{% endif %}>Ressources</a>
        </nav>
        <div class="header__actions">
            <button class="header__search-btn" id="searchOpen" aria-label="Rechercher">🔍</button>
            <button class="header__subscribe-btn" onclick="document.getElementById('newsletter').scrollIntoView({behavior:'smooth'})">S'abonner</button>
            <button class="header__menu-toggle" id="menuToggle" aria-label="Menu">☰</button>
        </div>
    </div>
</header>

