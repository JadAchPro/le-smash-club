---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    <url>
        <loc>{{ site.url }}/</loc>
        <lastmod>{{ collections.articles[0].date | dateISO }}</lastmod>
        <changefreq>daily</changefreq>
        <priority>1.0</priority>
    </url>
    {%- for article in collections.articles %}
    <url>
        <loc>{{ site.url }}{{ article.url }}</loc>
        <lastmod>{{ article.data.lastmod | dateISO if article.data.lastmod else article.date | dateISO }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
    </url>
    {%- endfor %}
    {%- for cat in site.categories %}
    <url>
        <loc>{{ site.url }}/{{ cat.slug }}/</loc>
        <changefreq>weekly</changefreq>
        <priority>0.6</priority>
    </url>
    {%- endfor %}
    <url>
        <loc>{{ site.url }}/a-propos/</loc>
        <changefreq>monthly</changefreq>
        <priority>0.4</priority>
    </url>
    <url>
        <loc>{{ site.url }}/contact/</loc>
        <changefreq>monthly</changefreq>
        <priority>0.4</priority>
    </url>
</urlset>
